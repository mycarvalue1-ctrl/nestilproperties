rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      // In a real app, this should check a custom claim or a document, not a hardcoded email.
      return isSignedIn() && request.auth.token.email == 'helpnestil@gmail.com';
    }
    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /favorite_properties/{propertyId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    match /properties/{propertyId} {
      // Public can read any single property or list them all.
      // Client is responsible for filtering `isApproved == true` for public views.
      allow get, list: if true;

      // Signed-in users can create properties for themselves.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      // Owner or Admin can update/delete.
      allow update, delete: if isSignedIn() && (isOwner(resource.data.ownerId) || isAdmin());
    }

    match /propertyPrivateDetails/{propertyId} {
      // Logged-in users can read (will be debited in client logic).
      allow get: if isSignedIn();
      allow list: if false; // No listing of all private details.

      // Owner or Admin can write.
      // This rule requires a get() which has billing implications.
      allow write: if isSignedIn() && (isOwner(get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId) || isAdmin());
    }

    match /site_visits/{visitId} {
      allow get: if isAdmin() || isOwner(resource.data.ownerId) || isOwner(resource.data.visitorId);
      allow list: if isAdmin();
      allow create: if isOwner(request.resource.data.visitorId);
      allow update: if isAdmin() || isOwner(resource.data.ownerId);
      allow delete: if false;
    }

    match /amenities/{amenityId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
  }
}
