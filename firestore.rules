rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read access to properties.
    match /properties/{propertyId} {
      // Explicitly allow get (single document) and list (collection query) for anyone.
      allow get, list: if true;

      // For now, allow anyone to write, since user authentication is disabled.
      // This should be secured if you re-enable user logins.
      allow write: if true;
    }

    // This collection stores owner contact details, also open for now
    match /propertyPrivateDetails/{propertyId} {
      allow read, write: if true;
    }
  }
}
