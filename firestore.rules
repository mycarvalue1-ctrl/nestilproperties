rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =================================
    // Helper Functions
    // =================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Safely check for admin UID, ensuring user is signed in first.
      return isSignedIn() && request.auth.uid == 'IultEIQMgAUPwoqAEWX7ZIunjNB3';
    }

    function isOwner(ownerId) {
      // Checks if the requesting user is the owner of the resource.
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // =================================
    // User Profile Rules
    // =================================
    match /users/{userId} {
      allow read, update: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow delete: if isAdmin();
      allow list: if isAdmin();
    }

    // =================================
    // Favorite Properties (Subcollection)
    // =================================
    match /users/{userId}/favorite_properties/{favoritePropertyId} {
      // User can manage their own favorites, admin has full access to all favorites.
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // =================================
    // Properties Collection Rules
    // =================================
    match /properties/{propertyId} {
      // ADMIN OVERRIDE: Admins have full read and write access.
      // This rule is checked first and provides a clear path for admin requests.
      allow read, write: if isAdmin();
      
      // NON-ADMIN WRITE Rules:
      // Allow non-admins to create properties and update their own.
      allow create: if isOwner(request.resource.data.ownerId);
      allow update: if isOwner(resource.data.ownerId);

      // NON-ADMIN READ Rules:
      // Allow non-admins to get a single doc if it's approved or they own it.
      allow get: if isOwner(resource.data.ownerId) || resource.data.isApproved == true;
      
      // Allow non-admins to list docs if they are querying for approved properties
      // OR for their own properties.
      allow list: if request.query.where.get("isApproved") == true ||
                     request.query.where.get("ownerId") == request.auth.uid;
    }


    // =================================
    // Site Visit Rules
    // =================================
     match /site_visits/{visitId} {
      // Allow read if admin, owner of the property, or the visitor who requested it.
      allow read: if isAdmin() || isOwner(resource.data.ownerId) || isOwner(resource.data.visitorId);

      // Allow update if admin or owner of the property.
      allow update: if isAdmin() || isOwner(resource.data.ownerId);

      // Allow create if the person creating it is the visitor.
      allow create: if isOwner(request.resource.data.visitorId);

      // Deletion is disabled for record-keeping.
      allow delete: if false;
    }

    // =================================
    // Static Data Collections
    // =================================
    match /amenities/{amenityId} {
      allow get, list: if true;
      allow write: if isAdmin(); // create, update, delete
    }

    match /nearby_place_types/{nearbyPlaceTypeId} {
      allow get, list: if true;
      allow write: if isAdmin(); // create, update, delete
    }
  }
}
