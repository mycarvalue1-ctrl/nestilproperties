rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =================================
    // Helper Functions
    // =================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Safely check for admin UID, ensuring user is signed in first.
      return isSignedIn() && request.auth.uid == 'IultEIQMgAUPwoqAEWX7ZIunjNB3';
    }

    function isOwner(ownerId) {
      // The user is the owner of a document if they are signed in AND their UID matches the ownerId field.
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // =================================
    // User Profile Rules
    // =================================
    match /users/{userId} {
      allow read, update: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow delete: if isAdmin();
      allow list: if isAdmin();
    }

    // =================================
    // Favorite Properties (Subcollection)
    // =================================
    match /users/{userId}/favorite_properties/{favoritePropertyId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // =================================
    // Properties Collection Rules
    // =================================
    match /properties/{propertyId} {
      // --- ADMIN OVERRIDE ---
      // Rule 1: Admins can do anything. This is checked first and stops further evaluation.
      allow read, write: if isAdmin();

      // --- WRITE RULES FOR NON-ADMINS ---
      // Rule 2: A signed-in, non-admin can create a property for themselves.
      allow create: if !isAdmin() && isSignedIn() && isOwner(request.resource.data.ownerId);

      // Rule 3: A signed-in, non-admin owner can update or delete their own property.
      allow update, delete: if !isAdmin() && isSignedIn() && isOwner(resource.data.ownerId);

      // --- READ RULES FOR NON-ADMINS ---

      // GET (Single Document) Rules:
      // Rule 4: ANYONE (public, user, etc.) can GET a single document if it is approved.
      allow get: if resource.data.isApproved == true;
      // Rule 5: A signed-in owner can GET their own document, regardless of approval status.
      allow get: if isSignedIn() && isOwner(resource.data.ownerId);
      
      // LIST (Query) Rules:
      // Rule 6: PUBLIC list. ANYONE can perform a list query IF it filters for approved properties.
      allow list: if request.query.where.isApproved == true;
      // Rule 7: OWNER list. A signed-in user can list their own properties.
      allow list: if isSignedIn() && request.query.where.ownerId == request.auth.uid;
    }


    // =================================
    // Site Visit Rules
    // =================================
     match /site_visits/{visitId} {
      // An admin, property owner, or visitor can read a visit request.
      allow read: if isAdmin() || isOwner(resource.data.ownerId) || isOwner(resource.data.visitorId);
      // An admin or property owner can update the status (confirm/reject).
      allow update: if isAdmin() || isOwner(resource.data.ownerId);
      // A visitor can create a request for themselves.
      allow create: if isOwner(request.resource.data.visitorId);
      // Deletion is disabled for record-keeping.
      allow delete: if false;
    }

    // =================================
    // Static Data Collections
    // =================================
    match /amenities/{amenityId} {
      // Anyone can read the list of amenities.
      allow get, list: if true;
      // Only admins can write to the list of amenities.
      allow write: if isAdmin();
    }

    match /nearby_place_types/{nearbyPlaceTypeId} {
      // Anyone can read the list of nearby place types.
      allow get, list: if true;
      // Only admins can write to this list.
      allow write: if isAdmin();
    }
  }
}
