rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Public read access, anyone can create, update, delete for now
    match /properties/{propertyId} {
      allow read, write: if true;
    }

    // This collection stores owner contact details, also open for now
    match /propertyPrivateDetails/{propertyId} {
      allow read, write: if true;
    }
  }
}
