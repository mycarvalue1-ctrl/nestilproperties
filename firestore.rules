rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Admin check using the specific UID provided by the user.
    function isAdmin() {
      return isSignedIn() && request.auth.uid == 'IultEIQMgAUPwoqAEWX7ZIunjNB3';
    }

    // User profile rules
    match /users/{userId} {
      allow get: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && request.resource.data.id == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Favorite properties rules (user-owned subcollection)
    match /users/{userId}/favorite_properties/{favoritePropertyId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Properties collection rules
    match /properties/{propertyId} {
      // LIST: Allows three types of collection queries.
      // 1. Admins can list all properties without filters.
      // 2. Public users can list properties IF they filter for approved ones.
      // 3. Logged-in users can list their own properties by filtering on ownerId.
      allow list: if isAdmin() ||
                     request.query.where('isApproved', '==', true) ||
                     (isSignedIn() && request.query.where('ownerId', '==', request.auth.uid));

      // GET: Allows reading a single document.
      // 1. Admins can get any property.
      // 2. Owners can get their own property.
      // 3. Anyone can get a property IF it is approved.
      allow get: if isAdmin() ||
                    (isSignedIn() && resource.data.ownerId == request.auth.uid) ||
                    resource.data.isApproved == true;

      // CREATE: Any signed-in user can create a property.
      // The ownerId in the new document must match the creator's UID.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      // UPDATE / DELETE: Only the owner or an admin can modify/delete.
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // Static data collections (admin-write, public-read)
    match /amenities/{amenityId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /nearby_place_types/{nearbyPlaceTypeId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
  }
}
