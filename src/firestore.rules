
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // This logic must match the front-end check in /admin/layout.tsx
      return request.auth != null && request.auth.token.email == 'helpnestil@gmail.com';
    }

    // Rules for the 'properties' collection
    match /properties/{propertyId} {
      // READ (get a single document)
      // Allow if property is approved, OR if the reader is the owner, OR if the reader is an admin.
      allow get: if (resource.data.listingStatus == 'approved') || 
                    (resource.data.ownerId != null && isOwner(resource.data.ownerId)) || 
                    isAdmin();

      // LIST (query for documents)
      // Allow authenticated users to perform list queries.
      // The security of these queries is then enforced by the 'get' rule above.
      // A query will only succeed if it *only* returns documents the user has 'get' access to.
      allow list: if request.auth != null;

      // CREATE: An authenticated user can create a property for themselves.
      // Rule enforces that the ownerId in the document matches the user's UID and the property starts as unapproved.
      allow create: if isOwner(request.resource.data.ownerId)
                    && request.resource.data.isApproved == false;

      // UPDATE: An owner can update their own properties, but CANNOT change the isApproved status.
      // An admin can update any field on any property.
      allow update: if (isOwner(resource.data.ownerId) && request.resource.data.isApproved == resource.data.isApproved)
                    || isAdmin();

      // DELETE: Only admins can delete properties.
      allow delete: if isAdmin();
    }

    // Rules for the 'propertyPrivateDetails' collection
    match /propertyPrivateDetails/{propertyId} {
      // Only the property owner or an admin can read the private details.
      allow read: if isOwner(resource.data.ownerId) || isAdmin();

      // Only the property owner or an admin can create or update the private details.
      allow write: if isOwner(request.resource.data.ownerId) || isAdmin();
    }

    // Rules for user-specific data, like favorites.
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
  }
}
